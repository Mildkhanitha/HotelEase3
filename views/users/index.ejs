<%- include('../partials/header') %>

<div class="container">
  <div class="card">
    <h2>User List</h2>
    <table>
      <tr>
        <th>Username</th>
        <th>Email</th>
        <th>Role</th>
      </tr>

      <% users.forEach(user => { %>
        <tr>
          <td><%= user.username %></td>
          <td><%= user.email %></td>
          <td><%= user.role %></td>
        </tr>
      <% }) %>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
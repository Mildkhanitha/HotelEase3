<%- include('../partials/header') %>

<div class="container">
  <div class="card">
    <h2>แก้ไขโรงแรม</h2>

    <form action="/hotels/<%= hotel.id %>?_method=PUT" method="POST">
      <label>ชื่อโรงแรม</label>
      <input type="text" name="hotel_name" value="<%= hotel.hotel_name %>" required>

      <label>ที่ตั้ง</label>
      <input type="text" name="location" value="<%= hotel.location %>" required>

      <label>ที่อยู่</label>
      <input type="text" name="address" value="<%= hotel.address %>">

      <label>คะแนน</label>
      <input type="number" step="0.1" name="rating" value="<%= hotel.rating %>">

      <button class="btn btn-success">อัปเดต</button>
      <a href="/hotels" class="btn">ยกเลิก</a>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
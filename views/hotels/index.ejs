<%- include('../partials/header') %>

<div class="container">
  <div class="card">
    <h2>รายการโรงแรม</h2>

    <a href="/hotels/new" class="btn btn-success">+ เพิ่มโรงแรม</a>

    <table>
      <thead>
        <tr>
          <th>ชื่อโรงแรม</th>
          <th>ที่ตั้ง</th>
          <th>คะแนน</th>
          <th>จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% hotels.forEach(hotel => { %>
          <tr>
            <td><%= hotel.hotel_name %></td>
            <td><%= hotel.location %></td>
            <td>⭐ <%= hotel.rating %></td>
            <td>
              <a href="/hotels/<%= hotel.id %>" class="btn btn-primary">ดู</a>
              <a href="/hotels/<%= hotel.id %>/edit" class="btn btn-success">แก้ไข</a>

              <form action="/hotels/<%= hotel.id %>?_method=DELETE" method="POST" style="display:inline;">
                <button class="btn btn-danger" onclick="return confirm('ลบโรงแรมนี้?')">ลบ</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
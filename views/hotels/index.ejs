<%- include('../partials/header') %>

<div class="container">

  <h2 class="section-title">ค้นหาโรงแรม</h2>

  <!-- FILTER BAR -->
  <form method="GET" action="/hotels" class="filter-bar">
    <input type="text" name="location" placeholder="จังหวัด / สถานที่"
      value="<%= requestQuery.location || '' %>">

    <input type="number" name="minPrice" placeholder="งบต่ำสุด"
      value="<%= requestQuery.minPrice || '' %>">

    <input type="number" name="maxPrice" placeholder="งบสูงสุด"
      value="<%= requestQuery.maxPrice || '' %>">

    <button type="submit" class="search-btn">ค้นหา</button>
  </form>

  <h2 class="section-title">โรงแรมทั้งหมด</h2>

  <div class="hotel-grid">
    <% hotels.forEach(hotel => { %>
      <div class="hotel-card">
        <img src="<%= hotel.image_url || 'https://images.unsplash.com/photo-1566073771259-6a8506099945' %>">

        <div class="hotel-info">
          <h3><%= hotel.hotel_name %></h3>
          <p>📍 <%= hotel.location %></p>
          <p>⭐ <%= hotel.rating || 'ไม่มีคะแนน' %></p>

          <div class="price">
            ฿<%= hotel.price_per_night || 1500 %> / คืน
          </div>

          <a href="/hotels/<%= hotel.id %>" class="card-btn">
            ดูรายละเอียด
          </a>
        </div>
      </div>
    <% }) %>
  </div>

</div>

<%- include('../partials/footer') %>